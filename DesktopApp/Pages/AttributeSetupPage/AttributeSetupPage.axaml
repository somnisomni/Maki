<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:page="clr-namespace:Somni.Maki.Pages.AttributeSetupPage"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:Class="Somni.Maki.Pages.AttributeSetupPage.AttributeSetupPage"
             x:DataType="page:AttributeSetupPageViewModel">
    <Design.DataContext>
        <page:AttributeSetupPageViewModel />
    </Design.DataContext>

    <TextBlock>Attribute Page</TextBlock>
</UserControl>